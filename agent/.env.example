# Copy this file to .env (next to aurigon-agent.exe) and fill in the real
# key from your dashboard's Download Agent page. .env is gitignored — never
# commit a real key.
#
# A real environment variable (set via NSSM, etc.) always takes priority
# over this file, so it's safe to leave in place either way.

# Required — the permanent AGT-... key from Download Agent in the dashboard.
AURIGON_AGENT_KEY=

# Optional — how often the agent polls, in seconds. Default 30, minimum 10.
AURIGON_SYNC_INTERVAL_SECONDS=

# DEV/TEST ONLY — trusts a self-signed backend certificate. Never set this
# to true once the backend has a real CA-signed certificate.
AURIGON_INSECURE_SKIP_VERIFY=
