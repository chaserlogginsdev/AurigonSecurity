# Copy this file to .env and fill in real values.
# .env itself is gitignored — never commit real secrets.
#
# Real environment variables (set via NSSM, the shell, etc.) always take
# priority over this file, so it's safe to leave a .env file in place even
# if you also set some of these elsewhere.

# Required — signs dashboard session tokens. Generate a real random value,
# don't hand-type something memorable. 32+ characters minimum.
AURIGON_JWT_SECRET=

# Required on first run only — sets the initial admin password when the
# first tenant is auto-provisioned. Not needed after that.
AURIGON_ADMIN_PASSWORD=

# Optional — identity of the auto-provisioned first tenant.
AURIGON_TENANT_SLUG=default
AURIGON_TENANT_NAME=Default Tenant

# Optional — defaults to 8080.
AURIGON_PORT=8080

# Optional — enables HTTPS. Both must be set together.
AURIGON_TLS_CERT_FILE=
AURIGON_TLS_KEY_FILE=

# Optional — comma-separated list of allowed dashboard origins for CORS.
# Required before deploying to a real domain — see the startup warning
# if this is unset.
AURIGON_ALLOWED_ORIGINS=

# Optional — protects /tenants and /tenants/create (platform-operator-only
# endpoints for provisioning new tenants). Leave unset to keep these
# endpoints fully disabled — the safe default. Set a long random value
# here and send it as the X-Operator-Key header only when you actually
# need to provision a new tenant.
AURIGON_OPERATOR_KEY=
